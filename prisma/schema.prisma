generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String   @db.Text
  price        Float    // verkoopprijs (wat de klant betaalt)
  listPrice    Float?   // adviesprijs; indien > price → korting (doorgestreept)
  category     String
  images       String   @db.Text
  specs        String?  @db.Text
  // Maat-varianten met eigen prijs (JSON-array), bv. bedden:
  // [{"label":"140 × 200","price":599},{"label":"160 × 200","price":699}]
  // Leeg/null = product met één vaste prijs (price-veld).
  sizeVariants String?  @db.Text
  featured     Boolean  @default(false)
  stock        Int      @default(10)
  deliveryTime String?
  colorGroup   String?
  colorName    String?
  colorHex     String?
  source       String?   // Herkomst/leverancier (bv. "Rousseau") — admin-tag
  hidden       Boolean  @default(false)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orderItems   OrderItem[]

  @@index([category])
  @@index([colorGroup])
  @@index([hidden])
  @@index([deletedAt])
  @@index([source])
}

model DeletedImage {
  id          String   @id @default(cuid())
  productId   String?
  productSlug String
  publicId    String
  url         String   @db.Text
  w           Int?
  h           Int?
  deletedAt   DateTime @default(now())

  @@index([deletedAt])
  @@index([productId])
}

model Order {
  id         String      @id @default(cuid())
  orderNumber String     @unique
  total      Float
  status     String      @default("pending")
  firstName  String
  lastName   String
  email      String
  phone      String      @default("")
  address    String
  houseNumber String     @default("")
  city       String
  zipCode    String
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
