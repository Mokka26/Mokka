generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String   @db.Text
  price        Float    // verkoopprijs (wat de klant betaalt)
  listPrice    Float?   // adviesprijs; indien > price → korting (doorgestreept)
  category     String
  images       String   @db.Text
  specs        String?  @db.Text
  // Maat-varianten met eigen prijs (JSON-array), bv. bedden:
  // [{"label":"140 × 200","price":599},{"label":"160 × 200","price":699}]
  // Leeg/null = product met één vaste prijs (price-veld).
  sizeVariants String?  @db.Text
  // Nachtkast-optie (bedden), per bed in te stellen in de admin:
  //   nachtkastMode: "included" (inbegrepen), "optional" (apart bij te
  //   bestellen) of null/"none" (geen nachtkast).
  //   nachtkastPrice  = prijs voor 1 nachtkast, nachtkastPrice2 = prijs voor 2.
  nachtkastMode   String?
  nachtkastPrice  Float?
  nachtkastPrice2 Float?
  // Voetbank-optie (bedden), zelfde standen als nachtkast: "included",
  // "optional" (0/1 tegen voetbankPrice) of null/"none".
  voetbankMode    String?
  voetbankPrice   Float?
  featured     Boolean  @default(false)
  stock        Int      @default(10)
  deliveryTime String?
  colorGroup   String?
  colorName    String?
  colorHex     String?
  source       String?   // Herkomst/leverancier (bv. "Rousseau") — admin-tag
  hidden       Boolean  @default(false)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orderItems   OrderItem[]

  @@index([category])
  @@index([colorGroup])
  @@index([hidden])
  @@index([deletedAt])
  @@index([source])
}

// Simpele DB-backed rate-limiter (werkt over serverless-instances heen).
// key = bv. "login:<ip>" of "checkout:<ip>"; teller per tijdvenster tot resetAt.
model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime
}

model DeletedImage {
  id          String   @id @default(cuid())
  productId   String?
  productSlug String
  publicId    String
  url         String   @db.Text
  w           Int?
  h           Int?
  deletedAt   DateTime @default(now())

  @@index([deletedAt])
  @@index([productId])
}

model Order {
  id         String      @id @default(cuid())
  orderNumber String     @unique
  total      Float
  shipping   Float       @default(0)
  status     String      @default("open") // open | paid | failed | canceled | expired
  molliePaymentId String?
  firstName  String
  lastName   String
  email      String
  phone      String      @default("")
  address    String
  houseNumber String     @default("")
  city       String
  zipCode    String
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([status])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  productName  String  @default("") // snapshot — overleeft prijs/naam-wijziging
  variantLabel String?              // gekozen maat, bv. "140 × 200"
  quantity     Int
  price        Float
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
